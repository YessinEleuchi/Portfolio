---
import experiences from "../collections/experiences.json";
import AboutExperience from "../components/about-experience.astro";
import PageHeading from "../components/page-heading.astro";
import Layout from "../layouts/main.astro";
---

<Layout title="About Me">
  <section class="relative z-20 max-w-2xl mx-auto my-12 px-7 lg:px-0">
    <PageHeading
  title="About Me"
  description="I’m a Software Engineer from Tunisia, passionate about full-stack development, automation, DevOps, and AI-powered solutions."
/>

    <img src="/assets/images/about.png" class="relative z-30 w-full my-10 rounded-xl" />

    <h2 class="mb-2 text-2xl font-bold dark:text-neutral-200">Short Bio</h2>

<ul class="text-sm leading-6 text-gray-600 dark:text-neutral-400 sm:leading-7 lg:leading-8 sm:text-base lg:text-lg pl-6">
  <li class="list-none before:content-['▣'] before:mr-3 before:text-xl">
    I'm a Software Engineer and a graduate of IIT Sfax, specializing in full-stack development, artificial intelligence, and automation.
  </li>

  <li class="list-none before:content-['▣'] before:mr-3 before:text-xl">
    I build modern web applications using React, Next.js, Node.js, NestJS, FastAPI, PostgreSQL, and MongoDB.
  </li>

  <li class="list-none before:content-['▣'] before:mr-3 before:text-xl">
    My projects range from intelligent software estimation and monitoring platforms to computer vision and license plate recognition systems.
  </li>

  <li class="list-none before:content-['▣'] before:mr-3 before:text-xl">
    I'm passionate about clean architecture, DevOps, scalable backend systems, and human-centered AI solutions.
  </li>

  <li class="list-none before:content-['▣'] before:mr-3 before:text-xl">
    Curious and self-driven, I enjoy transforming complex business challenges into reliable and practical software solutions.
  </li>
</ul>






    <h2
      class="mt-5 mb-2 text-2xl font-bold lg:mt-10 sm:mt-6 dark:text-neutral-200"
    >
      Experience
    </h2>
 
    <div class="px-5 py-10">
      {
        experiences.map((experience) => {
          return (
            <div class="pb-10 border-l border-gray-200 last:border-l-0 dark:border-neutral-700">
              <AboutExperience
                dates={experience.dates}
                role={experience.role}
                company={experience.company}
                description={experience.description}
                logo={experience.logo}
              />
            </div>
          )
        })
      }
    </div>

    <h2 class="mt-5 mb-2 text-2xl font-bold lg:mt-10 sm:mt-6 dark:text-neutral-200">Let's Connect</h2>
    <p
      class="text-sm leading-6 text-gray-600 dark:text-neutral-400 sm:leading-7 lg:leading-8 sm:text-base lg:text-lg"
    >
      If you want to stay up to date with my work be sure to <a
        href="https://x.com/EleuchiYessin"
        target="_blank"
        class="text-indigo-600 underline">follow me on twitter</a
      >, or you can send me an <a href="mailto:yessineleuchi.embedded@gmail.com" class="text-indigo-600 underline"
        >email</a
      > and I'll be sure to get back to you.
    </p>
  </section>
</Layout>
